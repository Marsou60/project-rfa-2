{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RFA Application",
  "version": "0.1.0",
  "identifier": "com.groupement.rfa",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RFA Application",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1200,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "shortDescription": "Application RFA - Suivi et optimisation des remises",
    "longDescription": "Application RFA pour le suivi des performances et l'optimisation des remises fournisseurs.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBMTc4NzFEQzFDNEZGMDMKUldRRC84VEJIWWNYV3NrSGpzaHhPNGZ1RCtrdGZORnJVSnFxbFNDa25KUmdJTno3eldZTTR1elEK",
      "endpoints": [
        "https://github.com/Marsou60/project-rfa-2/releases/latest/download/latest.json"
      ]
    }
  }
}
